---
interface Props {
  statement: string;     // HTML allowed; wrap one keyword in <span class="mark">…</span>
  subhead: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
}
const { statement, subhead, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---
<section class="hero" aria-labelledby="hero-statement">
  <h1 class="hero-statement reveal reveal-1" id="hero-statement" set:html={statement}></h1>
  <p class="hero-subhead reveal reveal-2">{subhead}</p>
  <div class="hero-cta reveal reveal-3">
    <a class="hero-cta-primary" href={primaryHref}>{primaryLabel}</a>
    <span class="hero-cta-divider" aria-hidden="true">·</span>
    <a class="hero-cta-secondary" href={secondaryHref}>{secondaryLabel}</a>
  </div>
</section>

<style>
  .hero {
    max-width: var(--container-marketing);
    margin: 0 auto;
    padding: 5.5rem 1.5rem 4rem;
  }
  .hero-statement {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-display-xl);
    line-height: var(--leading-display);
    letter-spacing: -0.018em;
    color: var(--color-ink);
    max-width: 22ch;
    margin: 0;
    text-wrap: balance;
  }
  .hero-statement :global(.mark) {
    position: relative;
    display: inline-block;
    white-space: nowrap;
    color: var(--color-ink);
  }
  .hero-statement :global(.mark)::before {
    content: "";
    position: absolute;
    inset: auto 0 0.16em 0;
    height: 0.42em;
    background: var(--color-brand-tint);
    z-index: -1;
    transform: skewX(-2deg);
    border-radius: 1px;
  }
  .hero-subhead {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-h3);
    line-height: 1.55;
    color: var(--color-ink-soft);
    max-width: 40ch;
    margin: 1.75rem 0 0;
    text-wrap: pretty;
  }
  .hero-cta {
    margin-top: 2.5rem;
    display: flex;
    gap: 1.25rem;
    align-items: baseline;
    font-family: var(--font-display);
    font-size: var(--text-body);
  }
  .hero-cta-primary {
    color: var(--color-brand);
    font-weight: 500;
  }
  .hero-cta-primary:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 5px;
    text-decoration-color: var(--color-brand);
  }
  .hero-cta-divider {
    color: var(--color-ink-mute);
    user-select: none;
  }
  .hero-cta-secondary {
    color: var(--color-ink);
    border-bottom: 1px solid transparent;
    transition: border-color 200ms var(--ease-editorial);
  }
  .hero-cta-secondary:hover { border-color: var(--color-ink); }

  /* Stagger reveal */
  .reveal {
    opacity: 0;
    transform: translateY(8px);
    animation: reveal 700ms var(--ease-editorial) forwards;
  }
  .reveal-1 { animation-delay: 0ms; }
  .reveal-2 { animation-delay: 120ms; }
  .reveal-3 { animation-delay: 240ms; }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
