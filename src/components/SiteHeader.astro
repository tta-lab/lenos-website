---
interface Props {
  current?: 'home' | 'docs' | 'blog' | 'benchmarks';
}
const { current } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<header class="site-header">
  <div class="site-header-inner">
    <a href={base} class="wordmark" aria-label="Lenos home">
      <span>lenos</span>
      <span class="lambda" aria-hidden="true">λ</span>
    </a>
    <nav class="nav" aria-label="Primary">
      <a href={base} aria-current={current === 'home' ? 'page' : undefined}>Home</a>
      <a href={`${base}/docs`} aria-current={current === 'docs' ? 'page' : undefined}>Docs</a>
      <a href={`${base}/blog`} aria-current={current === 'blog' ? 'page' : undefined}>Blog</a>
      <a href={`${base}/benchmarks`} aria-current={current === 'benchmarks' ? 'page' : undefined}>Benchmarks</a>
      <a href="https://github.com/tta-lab/lenos" class="external" rel="noopener">GitHub</a>
      <button class="theme-toggle" type="button" aria-label="Toggle theme" id="themeToggle">
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('themeToggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('lenos-theme', next); } catch (e) {}
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgb(from var(--color-paper) r g b / 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-paper-rule);
  }
  .site-header-inner {
    max-width: var(--container-marketing);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .wordmark .lambda {
    color: var(--color-brand-gold);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 1.25rem;
    line-height: 1;
    transform: translateY(0.05em);
  }
  .nav {
    display: flex;
    gap: 1.75rem;
    align-items: baseline;
    font-family: var(--font-display);
    font-size: var(--text-small);
  }
  .nav a {
    position: relative;
    color: var(--color-ink-soft);
    transition: color 200ms var(--ease-editorial);
  }
  .nav a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -3px;
    height: 1px;
    background: var(--color-brand);
    transition: right 240ms var(--ease-editorial);
  }
  .nav a:hover { color: var(--color-ink); }
  .nav a:hover::after { right: 0; }
  .nav a[aria-current="page"] { color: var(--color-ink); }
  .nav a[aria-current="page"]::after { right: 0; }
  .nav a.external::after {
    content: "↗";
    position: static;
    height: auto;
    background: none;
    margin-left: 0.2em;
    font-size: 0.85em;
    color: var(--color-ink-mute);
  }
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    color: var(--color-ink-mute);
    transition: color 200ms var(--ease-editorial), background 200ms var(--ease-editorial);
  }
  .theme-toggle:hover { color: var(--color-ink); background: var(--color-paper-deep); }
  .theme-toggle svg { width: 16px; height: 16px; }
  .theme-toggle .icon-sun { display: none; }
  .theme-toggle .icon-moon { display: block; }
  :global([data-theme="dark"]) .theme-toggle .icon-sun { display: block; }
  :global([data-theme="dark"]) .theme-toggle .icon-moon { display: none; }
</style>
