---
interface Differentiator {
  marker: string;
  title: string;
  body: string;          // HTML allowed
  caption?: string;      // Italic small caption below body (e.g. citation line)
}
interface Props {
  items: Differentiator[];
}
const { items } = Astro.props;
---
<section class="differentiators" aria-label="Key differentiators">
  {items.map((item) => (
    <div class="differentiator">
      <div class="differentiator-marker">{item.marker}</div>
      <div class="differentiator-body">
        <h2 class="differentiator-title">{item.title}</h2>
        <p class="differentiator-prose" set:html={item.body}></p>
        {item.caption && (
          <p class="differentiator-caption" set:html={item.caption}></p>
        )}
      </div>
    </div>
  ))}
</section>

<style>
  .differentiators {
    max-width: var(--container-marketing);
    margin: 0 auto;
    padding: 0 1.5rem;
    border-top: 1px solid var(--color-paper-rule);
  }
  .differentiator {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 0 2rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-paper-rule);
  }
  .differentiator:last-child { border-bottom: none; }
  .differentiator-marker {
    font-family: var(--font-body);
    font-variant: small-caps;
    font-feature-settings: "smcp" 1;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-ink-mute);
    font-size: var(--text-small);
    font-variant-numeric: tabular-nums;
    padding-top: 0.45rem;
  }
  .differentiator-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .differentiator-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-display-m);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-ink);
  }
  .differentiator-prose {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-prose);
    color: var(--color-ink-soft);
    margin: 0;
    max-width: 56ch;
  }
  .differentiator-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-code-border);
    padding: 0.05em 0.4em;
    border-radius: 2px;
  }
  .differentiator-prose :global(em) { color: var(--color-ink); }
  .differentiator-prose :global(sup a) {
    color: var(--color-brand-gold);
    border-bottom: none;
  }
  .differentiator-caption {
    font-size: var(--text-small);
    color: var(--color-ink-mute);
    font-style: italic;
    margin-top: 0.6rem;
    line-height: 1.55;
  }
  .differentiator-caption :global(a) {
    color: var(--color-ink-soft);
    border-bottom: 1px solid var(--color-paper-rule);
  }
  .differentiator-caption :global(a:hover) {
    border-bottom-color: var(--color-ink-soft);
  }
  .differentiator-caption :global(code) {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.9em;
  }
  @media (max-width: 640px) {
    .differentiator { grid-template-columns: 1fr; gap: 0.5rem; }
  }
</style>
