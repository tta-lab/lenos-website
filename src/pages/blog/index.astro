---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const base = import.meta.env.BASE_URL;

// Posts hand-listed for v1. Migrate to content collections when count > ~6.
const posts = [
  {
    slug: "2026-05-introducing-lenos",
    title: "Lenos — an AI runtime by subtraction",
    description: "Why we forked Crush, what we removed, and the bet that it adds up.",
    date: "2026-05-06",
    author: "the lenos team",
  },
];
---
<BaseLayout title="Blog — lenos">
  <SiteHeader current="blog" />
  <main id="main" class="blog-shell">
    <article>
      <p class="eyebrow">Blog</p>
      <h1>Notes from the lenos team.</h1>
      <p class="lede">
        Posts on bash-first agent design, terminal benchmark results, and
        the small ideas behind a small runtime.
      </p>
      <ul class="post-list">
        {posts.map((p) => (
          <li class="post-item">
            <a href={`${base}/blog/${p.slug}`}>
              <p class="post-meta">{p.date} · {p.author}</p>
              <h2 class="post-title">{p.title}</h2>
              <p class="post-blurb">{p.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </article>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .blog-shell {
    max-width: var(--container-marketing);
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  article { max-width: var(--container-prose); }
  .eyebrow {
    font-family: var(--font-body);
    font-variant: small-caps;
    font-feature-settings: "smcp" 1;
    letter-spacing: 0.1em;
    font-size: var(--text-xs);
    color: var(--color-ink-mute);
    margin: 0 0 0.5rem;
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-display-l);
    letter-spacing: -0.012em;
    line-height: 1.15;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .lede {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-h3);
    line-height: 1.55;
    color: var(--color-ink-soft);
    margin: 0 0 2.5rem;
    max-width: 50ch;
  }
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-paper-rule);
  }
  .post-item {
    border-bottom: 1px solid var(--color-paper-rule);
  }
  .post-item a {
    display: block;
    padding: 1.5rem 0;
    transition: background 200ms var(--ease-editorial);
  }
  .post-item a:hover .post-title { color: var(--color-brand); }
  .post-meta {
    font-family: var(--font-body);
    font-variant: small-caps;
    font-feature-settings: "smcp" 1;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);
    color: var(--color-ink-mute);
    margin: 0 0 0.4rem;
  }
  .post-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-h2);
    line-height: 1.25;
    margin: 0 0 0.5rem;
    color: var(--color-ink);
    transition: color 200ms var(--ease-editorial);
  }
  .post-blurb {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-prose);
    color: var(--color-ink-soft);
    margin: 0;
    max-width: 60ch;
  }
</style>
